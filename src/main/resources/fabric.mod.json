{
	"schemaVersion": 1,
	"id": "nmbct-football",
	"version": "${version}",
	"name": "NMBCT Football",
	"description": "A football mod! You can play football game in Minecraft!",
	"authors": [
		"Astrorbits NMB Court Team"
	],
	"contact": {
		"homepage": "https://github.com/NMB-Court-Team",
		"sources": "https://github.com/NMB-Court-Team/NMBCT-Football"
	},
	"license": "MIT",
	"icon": "assets/nmbct-football/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "net.astrorbits.football.NMBCTFootball",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "net.astrorbits.football.client.NMBCTFootballClient",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
            "net.astrorbits.football.client.config.ModMenuIntegration"
		]
	},
	"mixins": [
		"nmbct-football.mixins.json",
		{
			"config": "nmbct-football.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*",
		"yet_another_config_lib_v3": ">=3.9.3+26.1-fabric"
	}
}